{% _layout 'layout.liquid' %}

{% _area title %}掲示板{% end_area %}

{% _area head_resource %}
{% end_area %}

{% _area page_body %}
<div>
 <h1>掲示板</h1>
  <p>ログインしました。</p>
  <p>ユーザー名: {{ LoginUserName }}</p>
  <p><a href="/Training.BBS/Web/w2.BBS.Front/account/settings">設定</a></p>
  <form method="post" action="/Training.BBS/Web/w2.BBS.Front/auth/logout">
    <button type="submit">ログアウト</button>
  </form>
  <hr />
<vue-forum></vue-forum>
</div>
{% end_area %}

{% _area component %}
<script type="text/x-template" id="vue-forum-template">
  <div>
    <h2>新規投稿</h2>

    <div>
      <p v-if="message">${ message }</p>
      <p v-if="errorMessage">${ errorMessage }</p>
    </div>

    <div>
      <label for="postTitle">タイトル</label>
      <input type="text" id="postTitle" v-model="newTitle" />
    </div>

    <div>
      <label for="postBody">本文</label>
      <textarea id="postBody" v-model="newBody"></textarea>
    </div>

    <div>
      <button @click="createPost" :disabled="isSaving">投稿する</button>
    </div>

    <hr />

    <h2>投稿一覧</h2>

    <p v-if="hasPosts === false">投稿はまだありません。</p>

    <div v-for="post in posts" :key="post.PostId">
      <div v-if="editingPostId === post.PostId">
        <div>
          <label>タイトル</label>
          <input type="text" v-model="editTitle" />
        </div>
        <div>
          <label>本文</label>
          <textarea v-model="editBody"></textarea>
        </div>
        <button @click="saveEdit(post.PostId)" :disabled="isUpdating">保存</button>
        <button @click="cancelEdit" :disabled="isUpdating">キャンセル</button>
      </div>

      <div v-else>
        <h3>${ post.Title }</h3>
        <p>投稿者: ${ post.UserName }</p>
        <p>${ post.Body }</p>

        <h4>返信</h4>
        <div v-for="reply in (post.Replies || [])" :key="reply.ReplyId">
          <p><strong>${ reply.UserName }</strong>: ${ reply.Body }</p>
        </div>
        <div>
          <label :for="'reply-' + post.PostId">返信を書く</label>
          <textarea :id="'reply-' + post.PostId" rows="2" v-model="replyDraft[post.PostId]"></textarea>
        </div>
        <div>
          <button type="button" @click="submitReply(post.PostId)" :disabled="replySavingPostId === post.PostId">返信する</button>
        </div>

        <div v-if="post.CanEdit">
          <button @click="startEdit(post)">編集</button>
          <button @click="deletePost(post.PostId)" :disabled="isDeletingId === post.PostId">削除</button>
        </div>
      </div>

      <hr />
    </div>

    <div>
      <button @click="movePage(page - 1)" :disabled="canPrevPage === false">前へ</button>
      <span>${ pageLabel }</span>
      <button @click="movePage(page + 1)" :disabled="canNextPage === false">次へ</button>
    </div>
  </div>
</script>

<script>
  {% _javascript key: "onload" %}
  g_vueManager.setComponent('vue-forum', {
    template: '#vue-forum-template',
    data() {
      return {
        posts: [],
        page: 1,
        pageCount: 1,
        totalCount: 0,
        newTitle: '',
        newBody: '',
        message: '',
        errorMessage: '',
        isSaving: false,
        editingPostId: null,
        editTitle: '',
        editBody: '',
        isUpdating: false,
        isDeletingId: null,
        replyDraft: {},
        replySavingPostId: null,
      };
    },
    computed: {
      hasPosts() {
        return this.posts.length > 0;
      },
      canPrevPage() {
        return this.page > 1;
      },
      canNextPage() {
        return this.page < this.pageCount;
      },
      pageLabel() {
        return `${this.page} / ${this.pageCount}`;
      },
    },
    mounted() {
      this.loadPosts(1);
    },
    methods: {
      startEdit(post) {
        this.editingPostId = post.PostId;
        this.editTitle = post.Title;
        this.editBody = post.Body;
        this.message = '';
        this.errorMessage = '';
      },
      cancelEdit() {
        this.editingPostId = null;
        this.editTitle = '';
        this.editBody = '';
      },
      saveEdit(postId) {
        this.message = '';
        this.errorMessage = '';

        const params = new URLSearchParams();
        params.append('postId', postId);
        params.append('title', this.editTitle);
        params.append('body', this.editBody);

        this.isUpdating = true;

        fetch('/Training.BBS/Web/w2.BBS.Front/api/forum/update', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
          },
          body: params.toString(),
        })
          .then((response) => {
            if (response.ok === false) {
              throw new Error(`HTTP ${response.status}`);
            }
            return response.json();
          })
          .then((result) => {
            if (result.IsSuccess === false) {
              this.errorMessage = result.Message;
              return;
            }

            this.message = result.Message;
            this.cancelEdit();
            return this.loadPosts(this.page);
          })
          .catch(() => {
            this.errorMessage = '投稿の更新に失敗しました。';
          })
          .finally(() => {
            this.isUpdating = false;
          });
      },
      deletePost(postId) {
        if (window.confirm('この投稿を削除しますか？') === false) {
          return;
        }

        this.message = '';
        this.errorMessage = '';

        const params = new URLSearchParams();
        params.append('postId', postId);

        this.isDeletingId = postId;

        fetch('/Training.BBS/Web/w2.BBS.Front/api/forum/delete', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
          },
          body: params.toString(),
        })
          .then((response) => {
            if (response.ok === false) {
              throw new Error(`HTTP ${response.status}`);
            }
            return response.json();
          })
          .then((result) => {
            if (result.IsSuccess === false) {
              this.errorMessage = result.Message;
              return;
            }

            this.message = result.Message;
            return this.loadPosts(this.page);
          })
          .catch(() => {
            this.errorMessage = '投稿の削除に失敗しました。';
          })
          .finally(() => {
            this.isDeletingId = null;
          });
      },
      submitReply(postId) {
        this.message = '';
        this.errorMessage = '';
        const body = (this.replyDraft[postId] || '').trim();
        if (body.length === 0) {
          this.errorMessage = '返信本文を入力してください。';
          return;
        }
        const params = new URLSearchParams();
        params.append('postId', postId);
        params.append('body', body);
        this.replySavingPostId = postId;
        fetch('/Training.BBS/Web/w2.BBS.Front/api/forum/reply', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
          },
          body: params.toString(),
        })
          .then((response) => {
            if (response.ok === false) {
              throw new Error(`HTTP ${response.status}`);
            }
            return response.json();
          })
          .then((result) => {
            if (result.IsSuccess === false) {
              this.errorMessage = result.Message;
              return;
            }
            this.message = result.Message;
            this.replyDraft = { ...this.replyDraft, [postId]: '' };
            return this.loadPosts(this.page);
          })
          .catch(() => {
            this.errorMessage = '返信に失敗しました。';
          })
          .finally(() => {
            this.replySavingPostId = null;
          });
      },
      loadPosts(page) {
        const url = `/Training.BBS/Web/w2.BBS.Front/api/forum/posts?page=${page}`;

        return fetch(url)
          .then((response) => {
            if (response.ok === false) {
              throw new Error(`HTTP ${response.status}`);
            }

            return response.json();
          })
          .then((result) => {
            if (result.IsSuccess === false) {
              this.errorMessage = result.Message;
              return;
            }

            this.posts = result.Posts;

            const nextDraft = { ...this.replyDraft };
            this.posts.forEach((p) => {
              if (nextDraft[p.PostId] === undefined) {
                nextDraft[p.PostId] = '';
              }
            });
            this.replyDraft = nextDraft;

            this.page = result.Page;
            this.pageCount = result.PageCount;
            this.totalCount = result.TotalCount;
            this.errorMessage = '';
          })
          .catch(() => {
            this.errorMessage = '投稿一覧の取得に失敗しました。';
          });
      },
      createPost() {
        this.message = '';
        this.errorMessage = '';

        const params = new URLSearchParams();
        params.append('title', this.newTitle);
        params.append('body', this.newBody);

        this.isSaving = true;

        fetch('/Training.BBS/Web/w2.BBS.Front/api/forum/create', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
          },
          body: params.toString(),
        })
          .then((response) => {
            if (response.ok === false) {
              throw new Error(`HTTP ${response.status}`);
            }

            return response.json();
          })
          .then((result) => {
            if (result.IsSuccess === false) {
              this.errorMessage = result.Message;
              return;
            }

            this.newTitle = '';
            this.newBody = '';
            this.message = result.Message;

            return this.loadPosts(1);
          })
          .catch(() => {
            this.errorMessage = '投稿に失敗しました。';
          })
          .finally(() => {
            this.isSaving = false;
          });
      },
      movePage(page) {
        if (page < 1) {
          return;
        }

        if (page > this.pageCount) {
          return;
        }

        this.loadPosts(page);
      },
    },
  });
  {% end_javascript %}
</script>
{% end_area %}
