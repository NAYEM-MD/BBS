{% _layout 'layout.liquid' %}

{% _area title %}掲示板 — 投稿詳細{% end_area %}

{% _area head_resource %}
<link rel="stylesheet" href="{{ RootUrl | append: '/styles/style.css' | hard_reload }}" />
{% end_area %}

{% _area page_body %}
<div class="page-wrap">
  <p><a href="{{ RootUrl | append: '/forum' }}">← 一覧へ</a></p>
  <p class="text-muted">ユーザー名: {{ LoginUserName }}</p>
  <hr class="rule" />
  <vue-forum-detail></vue-forum-detail>
</div>
{% end_area %}

{% _area component %}
<script type="text/x-template" id="vue-forum-detail-template">
  <div class="card detail-card">
    <div class="alert-box">
      <p v-if="message">${ message }</p>
      <p v-if="errorMessage">${ errorMessage }</p>
    </div>

    <p v-if="isLoading" class="text-muted">読み込み中…</p>

    <div v-if="post !== null && isLoading === false">
      <div v-if="editingPostId === post.PostId">
        <div class="field">
          <label class="field__label">タイトル</label>
          <input class="input" type="text" v-model="editTitle" />
        </div>
        <div class="field">
          <label class="field__label">本文</label>
          <textarea class="input" v-model="editBody"></textarea>
        </div>
        <button class="btn btn--primary btn--sm" type="button" @click="saveEdit(post.PostId)" :disabled="isUpdating">保存</button>
        <button class="btn btn--ghost btn--sm" type="button" @click="cancelEdit" :disabled="isUpdating">キャンセル</button>
      </div>

      <div v-else>
        <h1 class="page-title">${ post.Title }</h1>
        <p class="text-muted">投稿者: ${ post.UserName }</p>
        <p class="detail-body">${ post.Body }</p>

        <h2 class="reply-title">返信</h2>
        <div v-for="reply in (post.Replies || [])" :key="reply.ReplyId" class="reply-line">
          <p><strong>${ reply.UserName }</strong>: ${ reply.Body }</p>
        </div>

        <div class="field">
          <label class="field__label" for="reply-body">返信を書く</label>
          <textarea class="input" id="reply-body" rows="3" v-model="replyBody"></textarea>
        </div>
        <div class="field">
          <button class="btn btn--primary" type="button" @click="submitReply" :disabled="replySaving">返信する</button>
        </div>

        <div v-if="post.CanEdit" class="detail-actions">
          <button class="btn btn--outline btn--sm" type="button" @click="startEdit(post)">編集</button>
          <button class="btn btn--danger btn--sm" type="button" @click="deletePost(post.PostId)" :disabled="isDeleting">削除</button>
        </div>
      </div>
    </div>
  </div>
</script>

<script>
  {% _javascript key: "onload" %}
  g_vueManager.setComponent('vue-forum-detail', {
    template: '#vue-forum-detail-template',
    data() {
      return {
        postId: {{ PostId }},
        post: null,
        isLoading: true,
        message: '',
        errorMessage: '',
        editingPostId: null,
        editTitle: '',
        editBody: '',
        isUpdating: false,
        isDeleting: false,
        replyBody: '',
        replySaving: false,
      };
    },
    mounted() {
      this.loadPost();
    },
    methods: {
      loadPost() {
        this.errorMessage = '';
        this.isLoading = true;
        const url = `${window.apiRoot}/api/forum/post?postId=${this.postId}`;
        return fetch(url)
          .then((response) => {
            if (response.ok === false) {
              throw new Error(`HTTP ${response.status}`);
            }
            return response.json();
          })
          .then((result) => {
            if (result.IsSuccess === false) {
              this.errorMessage = result.Message || '投稿を読み込めませんでした。';
              this.post = null;
              return;
            }
            this.post = result.Post;
            this.errorMessage = '';
          })
          .catch(() => {
            this.errorMessage = '投稿の取得に失敗しました。';
            this.post = null;
          })
          .finally(() => {
            this.isLoading = false;
          });
      },
      startEdit(post) {
        this.editingPostId = post.PostId;
        this.editTitle = post.Title;
        this.editBody = post.Body;
        this.message = '';
        this.errorMessage = '';
      },
      cancelEdit() {
        this.editingPostId = null;
        this.editTitle = '';
        this.editBody = '';
      },
      saveEdit(postId) {
        this.message = '';
        this.errorMessage = '';
        const params = new URLSearchParams();
        params.append('postId', postId);
        params.append('title', this.editTitle);
        params.append('body', this.editBody);
        this.isUpdating = true;
        fetch(`${window.apiRoot}/api/forum/update`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
          },
          body: params.toString(),
        })
          .then((response) => {
            if (response.ok === false) {
              throw new Error(`HTTP ${response.status}`);
            }
            return response.json();
          })
          .then((result) => {
            if (result.IsSuccess === false) {
              this.errorMessage = result.Message;
              return;
            }
            this.message = result.Message;
            this.cancelEdit();
            return this.loadPost();
          })
          .catch(() => {
            this.errorMessage = '投稿の更新に失敗しました。';
          })
          .finally(() => {
            this.isUpdating = false;
          });
      },
      deletePost(postId) {
        if (window.confirm('この投稿を削除しますか？') === false) {
          return;
        }
        this.message = '';
        this.errorMessage = '';
        const params = new URLSearchParams();
        params.append('postId', postId);
        this.isDeleting = true;
        fetch(`${window.apiRoot}/api/forum/delete`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
          },
          body: params.toString(),
        })
          .then((response) => {
            if (response.ok === false) {
              throw new Error(`HTTP ${response.status}`);
            }
            return response.json();
          })
          .then((result) => {
            if (result.IsSuccess === false) {
              this.errorMessage = result.Message;
              return;
            }
            window.location.href = window.apiRoot + '/forum';
          })
          .catch(() => {
            this.errorMessage = '投稿の削除に失敗しました。';
          })
          .finally(() => {
            this.isDeleting = false;
          });
      },
      submitReply() {
        this.message = '';
        this.errorMessage = '';
        const body = (this.replyBody || '').trim();
        if (body.length === 0) {
          this.errorMessage = '返信本文を入力してください。';
          return;
        }
        const params = new URLSearchParams();
        params.append('postId', this.postId);
        params.append('body', body);
        this.replySaving = true;
        fetch(`${window.apiRoot}/api/forum/reply`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
          },
          body: params.toString(),
        })
          .then((response) => {
            if (response.ok === false) {
              throw new Error(`HTTP ${response.status}`);
            }
            return response.json();
          })
          .then((result) => {
            if (result.IsSuccess === false) {
              this.errorMessage = result.Message;
              return;
            }
            this.message = result.Message;
            this.replyBody = '';
            return this.loadPost();
          })
          .catch(() => {
            this.errorMessage = '返信に失敗しました。';
          })
          .finally(() => {
            this.replySaving = false;
          });
      },
    },
  });
  {% end_javascript %}
</script>
{% end_area %}
