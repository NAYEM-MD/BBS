{% _area title %}ログイン{% end_area %}

{% _area head_resource %}
<link rel="stylesheet" href="{{ RootUrl | append: '/styles/style.css' | hard_reload }}" />
{% end_area %}

{% _area page_body %}
<div class="login-container">
  <h1>ログイン</h1>

  <div class="messages">
    {% if InfoMessage != blank %}
    <p>{{ InfoMessage }}</p>
    {% endif %}

    {% if ErrorMessage != blank %}
    <p>{{ ErrorMessage }}</p>
    {% endif %}
  </div>

  <form method="post" action="{{ RootUrl | append: '/auth/login' }}">
    <div>
      <label for="loginId">ログインID</label>
      <input type="text" id="loginId" name="LoginId" value="{{ LoginId }}" />
    </div>

    <div>
      <label for="password">パスワード</label>
      <input type="password" id="password" name="Password" value="{{ Password }}" />
    </div>

    <div>
      <button type="submit">ログイン</button>
    </div>
  </form>

  <div class="footer-link">
    <a href="{{ RootUrl | append: '/auth/register' }}">会員登録はこちら</a>
  </div>
</div>
{% end_area %}

{% _area component %}
{% end_area %}
